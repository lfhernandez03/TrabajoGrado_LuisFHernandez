# ═══════════════════════════════════════════════════════════════════════════════
# Application Settings
# ═══════════════════════════════════════════════════════════════════════════════

APP_ENV=development                 # development | production
APP_PORT=8000

# ═══════════════════════════════════════════════════════════════════════════════
# Database Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# MongoDB - For local Docker: use service name 'mongodb'
# For external/Atlas: use full connection string
MONGO_USER=root
MONGO_PASS=password
MONGO_URI=mongodb://root:password@mongodb:27017/movie-graph-rag?authSource=admin

# ═══════════════════════════════════════════════════════════════════════════════
# Fuseki RDF Store (Apache Jena)
# ═══════════════════════════════════════════════════════════════════════════════

FUSEKI_URL=http://fuseki:3030
FUSEKI_DATASET=Cine
FUSEKI_USER=admin
FUSEKI_PASSWORD=admin
FUSEKI_TIMEOUT_SECONDS=8
FUSEKI_MAX_RETRIES=3

# ═══════════════════════════════════════════════════════════════════════════════
# JWT Security (REQUIRED for production)
# ═══════════════════════════════════════════════════════════════════════════════

# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here_change_in_production

# ═══════════════════════════════════════════════════════════════════════════════
# LLM Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# Gemini (used by recommendation/chat pipeline)
# Get key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Groq (used by compute_network_metrics.py for cluster labelling)
# Free tier at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ═══════════════════════════════════════════════════════════════════════════════
# CORS & Admin
# ═══════════════════════════════════════════════════════════════════════════════

# CORS Configuration (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Admin emails (comma-separated for multiple)
ADMIN_EMAILS=admin@example.com

# ═══════════════════════════════════════════════════════════════════════════════
# Notes for Docker Compose
# ═══════════════════════════════════════════════════════════════════════════════

# For docker-compose.yml:
# - Use 'mongodb' as hostname (service name in compose)
# - Use 'fuseki' as hostname (service name in compose)
# - MongoDB credentials must match docker-compose environment vars

# For docker-compose.local.yml (MongoDB Atlas):
# - Replace MONGO_URI with your MongoDB Atlas connection string
# - Example: mongodb+srv://user:pass@cluster.mongodb.net/movie-graph-rag
# - Fuseki still runs locally
