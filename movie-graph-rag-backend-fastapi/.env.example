# Application Settings
APP_ENV=development  # or 'production'
APP_PORT=8000

# Security (REQUIRED for production)
JWT_SECRET=change_me_to_a_secure_random_string  # Use 'openssl rand -hex 32' to generate

# Database
MONGO_URI=mongodb://localhost:27017/movie-graph-rag

# Fuseki RDF Store
FUSEKI_URL=http://localhost:3030
FUSEKI_DATASET=movies
FUSEKI_USER=  # Leave empty if no authentication
FUSEKI_PASSWORD=  # Leave empty if no authentication
FUSEKI_TIMEOUT_SECONDS=8
FUSEKI_MAX_RETRIES=3

# LLM Configuration — Gemini (used by the recommendation/chat pipeline)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Groq (used by scripts/compute_network_metrics.py for cluster labelling)
# Free tier at console.groq.com — llama-3.1-8b-instant is recommended
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# CORS Configuration (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Admin Configuration
ADMIN_EMAILS=admin@example.com
