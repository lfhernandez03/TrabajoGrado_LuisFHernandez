# Movie-Graph-RAG Ontologies Configuration

# ============================================================================
# API KEYS (REQUIRED) - Must be obtained from the respective API providers
# ============================================================================

# OMDb API Key
# Get it from: https://www.omdbapi.com/apikey.aspx
# Plans: Free (1,000 req/day) or Paid
OMDB_API_KEY=your_omdb_api_key_here

# TheMovieDB (TMDb) API Key  
# Get it from: https://www.themoviedb.org/settings/api
# Plans: Free or Paid
TMDB_API_KEY=your_tmdb_api_key_here

# ============================================================================
# FUSEKI RDF STORE CONFIGURATION
# ============================================================================

# Fuseki Server URL (where the RDF triple store runs)
FUSEKI_URL=http://localhost:3030

# Fuseki Dataset name (the specific graph to store RDF data)
FUSEKI_DATASET=movies

# Fuseki Authentication (leave empty if authentication is disabled)
# IMPORTANT: These are used ONLY by environment variables, never CLI arguments
FUSEKI_USER=admin

# Fuseki password (should be a secure string in production)
FUSEKI_PASSWORD=change_me

# ============================================================================
# PIPELINE CONFIGURATION
# ============================================================================

# Maximum number of movies to process (leave empty for all)
# Useful for testing: set to 100 or 500 for quick runs
MAX_MOVIES=

# Whether to process movies incrementally (merge with existing) or replace all
INCREMENTAL=true
