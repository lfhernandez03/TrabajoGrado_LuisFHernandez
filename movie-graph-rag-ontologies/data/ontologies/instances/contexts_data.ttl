@prefix context: <http://www.semanticweb.org/movierecommendation/ontologies/2025/context-ontology#> .
@prefix contextdata: <http://www.semanticweb.org/movierecommendation/data/context/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

contextdata:User_user-001 a context:User ;
    context:userID "user-001"^^xsd:string ;
    context:userName "Luis Hernández"^^xsd:string ;
    rdfs:comment "Usuario de prueba principal"@es .

contextdata:User_user-002 a context:User ;
    context:userID "user-002"^^xsd:string ;
    context:userName "Camila Arcos"^^xsd:string ;
    rdfs:comment "Usuario de prueba secundario"@es .

contextdata:User_user-003 a context:User ;
    context:userID "user-003"^^xsd:string ;
    context:userName "Carlos Rodríguez"^^xsd:string ;
    rdfs:comment "Usuario de prueba familiar"@es .

contextdata:Mood_Joyful_1 a context:EmotionalContext ;
    context:desiredEnergyLevel "medio"^^xsd:string ;
    context:emotionalNeed "entretenimiento para todos"^^xsd:string ;
    context:isMoodOfSnapshot contextdata:Context_Session2 ;
    context:moodDescription "alegre"^^xsd:string ;
    rdfs:comment "Tono alegre para ambiente familiar. Energía media: entretenimiento dinámico pero no abrumador."@es .

contextdata:Mood_Relaxed_1 a context:EmotionalContext ;
    context:desiredEnergyLevel "bajo"^^xsd:string ;
    context:emotionalNeed "desconectar del estrés laboral"^^xsd:string ;
    context:isMoodOfSnapshot contextdata:Context_Session1 ;
    context:moodDescription "relajado"^^xsd:string ;
    context:moodIntensity 0.7 ;
    rdfs:comment "Estado inferido de 'quiero relajarme'. Energía baja: busca película tranquila que no demande mucha atención."@es .

contextdata:Mood_Social_1 a context:EmotionalContext ;
    context:desiredEnergyLevel "alto"^^xsd:string ;
    context:emotionalNeed "consenso grupal, entretenimiento compartido"^^xsd:string ;
    context:isMoodOfSnapshot contextdata:Context_Session3 ;
    context:moodDescription "social"^^xsd:string ;
    rdfs:comment "Necesita película con amplio appeal. Energía alta para mantener grupo enganchado."@es .

contextdata:Mood_Stressed_1 a context:EmotionalContext ;
    context:desiredEnergyLevel "alto"^^xsd:string ;
    context:emotionalNeed "escapar del estrés, desconectar"^^xsd:string ;
    context:isMoodOfSnapshot contextdata:Context_Session4 ;
    context:moodDescription "estresado"^^xsd:string ;
    context:moodIntensity 0.8 ;
    rdfs:comment "Paradoja emocional: estresado pero busca energía alta. Quiere algo épico/intenso que lo saque del estrés, no terror que lo empeore."@es .

contextdata:Req_GroupConsensus_1 a context:RequirementContext ;
    context:contentRestrictions "nada muy polarizante"^^xsd:string ;
    context:excludedGenre "drama pesado, documental"^^xsd:string ;
    context:isRequirementOf contextdata:Context_Session3 ;
    context:negativeConstraint "sin películas muy lentas o contemplativas"^^xsd:string ;
    rdfs:comment "Exclusiones inferidas para mantener consenso grupal"@es .

contextdata:Req_KidFriendly_1 a context:RequirementContext ;
    context:contentRestrictions "apto para niños, sin violencia, sin terror"^^xsd:string ;
    context:excludedGenre "terror, thriller psicológico"^^xsd:string ;
    context:isRequirementOf contextdata:Context_Session2 ;
    context:negativeConstraint "sin escenas intensas, sin lenguaje adulto"^^xsd:string ;
    rdfs:comment "Restricciones críticas para contexto familiar. Incluye exclusiones explícitas de géneros y contenido inapropiado."@es .

contextdata:Req_NoHorror_1 a context:RequirementContext ;
    context:excludedGenre "terror, horror"^^xsd:string ;
    context:isRequirementOf contextdata:Context_Session4 ;
    context:negativeConstraint "sin sustos, sin atmósferas opresivas"^^xsd:string ;
    rdfs:comment "Exclusión explícita de terror. Prefiere acción/aventura épica para canalizar energía."@es .

contextdata:Req_ShortTime_1 a context:RequirementContext ;
    context:availableTime 60 ;
    context:contentRestrictions "nada muy intenso"^^xsd:string ;
    context:isRequirementOf contextdata:Context_Session1 ;
    rdfs:comment "Restricciones inferidas de 'tengo una hora' y 'algo ligero'"@es .

contextdata:Social_Alone_1 a context:SocialContext ;
    context:companionType "solo"^^xsd:string ;
    context:hasChildren false ;
    context:isCompanionIn contextdata:Context_Session1 ;
    rdfs:comment "Usuario viendo solo"@es .

contextdata:Social_Alone_2 a context:SocialContext ;
    context:companionType "solo"^^xsd:string ;
    context:hasChildren false ;
    context:isCompanionIn contextdata:Context_Session4 ;
    rdfs:comment "Usuario solo de madrugada"@es .

contextdata:Social_Family_1 a context:SocialContext ;
    context:companionType "familia con niños"^^xsd:string ;
    context:groupSize 4 ;
    context:hasChildren true ;
    context:isCompanionIn contextdata:Context_Session2 ;
    rdfs:comment "Familia con niños"@es .

contextdata:Social_Friends_1 a context:SocialContext ;
    context:companionType "amigos"^^xsd:string ;
    context:groupSize 6 ;
    context:hasChildren false ;
    context:isCompanionIn contextdata:Context_Session3 ;
    rdfs:comment "Grupo grande de amigos. Tamaño crítico: requiere 'crowd-pleasers'"@es .

contextdata:User_user_001 context:hasCurrentContext contextdata:Context_Session1 .

contextdata:Context_Session2 a context:ContextSnapshot ;
    context:dayOfWeek "Sábado"^^xsd:string ;
    context:feelsMood contextdata:Mood_Joyful_1 ;
    context:hasRequirement contextdata:Req_KidFriendly_1 ;
    context:hourOfDay 18 ;
    context:requestTimestamp "2026-01-10T18:00:00"^^xsd:dateTime ;
    context:snapshotID "ctx-002"^^xsd:string ;
    context:userIntent "Película familiar para el fin de semana con los niños"^^xsd:string ;
    context:withCompanion contextdata:Social_Family_1 ;
    rdfs:comment "Contexto inferido de: 'Buscamos algo para ver con los niños este fin de semana'. Temporal: Sábado 6:00 PM."@es .

contextdata:Context_Session3 a context:ContextSnapshot ;
    context:dayOfWeek "Viernes"^^xsd:string ;
    context:feelsMood contextdata:Mood_Social_1 ;
    context:hasRequirement contextdata:Req_GroupConsensus_1 ;
    context:hourOfDay 21 ;
    context:requestTimestamp "2026-01-10T21:00:00"^^xsd:dateTime ;
    context:snapshotID "ctx-003"^^xsd:string ;
    context:userIntent "Encontrar película que satisfaga a grupo grande de amigos"^^xsd:string ;
    context:withCompanion contextdata:Social_Friends_1 ;
    rdfs:comment "Contexto inferido de: 'Somos 6 amigos, queremos algo que a todos les guste'. Temporal: Viernes 9:00 PM."@es .

contextdata:Context_Session4 a context:ContextSnapshot ;
    context:dayOfWeek "Martes"^^xsd:string ;
    context:feelsMood contextdata:Mood_Stressed_1 ;
    context:hasRequirement contextdata:Req_NoHorror_1 ;
    context:hourOfDay 3 ;
    context:requestTimestamp "2026-01-07T03:00:00"^^xsd:dateTime ;
    context:snapshotID "ctx-004"^^xsd:string ;
    context:userIntent "Escapar del estrés con película intensa pero no de terror"^^xsd:string ;
    context:withCompanion contextdata:Social_Alone_2 ;
    rdfs:comment "Contexto inferido de: 'Son las 3 AM, estoy estresado, necesito desconectar pero nada de terror'. Temporal: Martes 3:00 AM (madrugada insomnio)."@es .

contextdata:Context_Session1 a context:ContextSnapshot ;
    context:dayOfWeek "Jueves"^^xsd:string ;
    context:feelsMood contextdata:Mood_Relaxed_1 ;
    context:hasRequirement contextdata:Req_ShortTime_1 ;
    context:hourOfDay 20 ;
    context:isContextOfUser contextdata:User_user_001 ;
    context:requestTimestamp "2026-01-09T20:30:00"^^xsd:dateTime ;
    context:snapshotID "ctx-001"^^xsd:string ;
    context:userIntent "Buscar algo ligero para relajarme después del trabajo"^^xsd:string ;
    context:withCompanion contextdata:Social_Alone_1 ;
    rdfs:comment "Contexto inferido del mensaje: 'Quiero ver algo ligero para relajarme, tengo una hora'. Temporal: Jueves 8:30 PM."@es .

