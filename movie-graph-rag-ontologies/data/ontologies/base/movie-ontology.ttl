@prefix : <http://www.semanticweb.org/movierecommendation/ontologies/2025/movie-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix movie: <http://data.linkedmdb.org/resource/movie/> .

<http://www.semanticweb.org/movierecommendation/ontologies/2025/movie-ontology> rdf:type owl:Ontology ;
    rdfs:label "Movie Domain Ontology for GraphRAG"@en ,
               "Ontología de Dominio Cinematográfico para GraphRAG"@es ;
    rdfs:comment "Cinematographic domain ontology optimized for recommendation systems with GraphRAG and LLM"@en ;
    owl:versionInfo "1.0" .

#################################################################
#    TABLE OF CONTENTS
#################################################################
# 1. Classes - Main Hierarchy
#    1.1 Entity (Root)
#    1.2 Movie and subclasses
#    1.3 Person and roles
#    1.4 Attributes (Genre, Keyword, NarrativeElement, etc.)
#    1.5 CulturalContext
#    1.6 Rating and AgeRating
#    1.7 ProductionCompany, Certification, Award
#    1.8 MovieCluster (GraphRAG)
#
# 2. Object Properties
#    2.1 Movie ↔ Person (full-duplex navigation)
#    2.2 Movie ↔ Attribute
#    2.3 Movie ↔ Movie (similarity)
#    2.4 Movie ↔ MovieCluster (GraphRAG)
#    2.5 Person ↔ Role
#    2.6 Role ↔ Movie
#    2.7 Award
#    2.8 Context Bridge
#
# 3. Data Properties
#    3.1 Movie (basic metadata, GraphRAG, ratings)
#    3.2 Person
#    3.3 Rating
#    3.4 Attributes (Genre, Keyword, Theme, Tone, etc.)
#    3.5 CulturalContext
#    3.6 AgeRating, Award, Role
#    3.7 MovieCluster (GraphRAG)
#
# 4. Axioms and Constraints
# 5. Example Instances
# 6. Annotations
#################################################################

#################################################################
#    Classes - Jerarquía Principal
#################################################################

###  Entity (Root Class)
:Entity rdf:type owl:Class ;
    rdfs:label "Entity"@en ,
               "Entidad"@es ;
    rdfs:comment "Root class grouping all entities in the cinematographic domain"@en .

###  Movie
:Movie rdf:type owl:Class ;
    rdfs:subClassOf :Entity ;
    owl:equivalentClass schema:Movie ,
                       dbo:Film ;
    rdfs:label "Movie"@en ,
               "Película"@es ;
    rdfs:comment "Cinematographic or audiovisual work"@en .

:FeatureFilm rdf:type owl:Class ;
    rdfs:subClassOf :Movie ;
    rdfs:label "Feature Film"@en ,
               "Largometraje"@es .

:Documentary rdf:type owl:Class ;
    rdfs:subClassOf :Movie ;
    rdfs:label "Documentary"@en ,
               "Documental"@es .

:ShortFilm rdf:type owl:Class ;
    rdfs:subClassOf :Movie ;
    rdfs:label "Short Film"@en ,
               "Cortometraje"@es .

:AnimatedFilm rdf:type owl:Class ;
    rdfs:subClassOf :Movie ;
    rdfs:label "Animated Film"@en ,
               "Película Animada"@es .

###  Person
:Person rdf:type owl:Class ;
    rdfs:subClassOf :Entity ;
    owl:equivalentClass schema:Person ,
                       dbo:Person ,
                       foaf:Person ;
    rdfs:label "Person"@en ,
               "Persona"@es ;
    rdfs:comment "Individual involved in film production"@en .

:Director rdf:type owl:Class ;
    rdfs:subClassOf :Person ;
    owl:equivalentClass schema:MovieDirector ,
                       dbo:Director ;
    rdfs:label "Director"@en ,
               "Director"@es .

:Actor rdf:type owl:Class ;
    rdfs:subClassOf :Person ;
    owl:equivalentClass schema:Actor ,
                       dbo:Actor ;
    rdfs:label "Actor"@en ,
               "Actor"@es .

:Producer rdf:type owl:Class ;
    rdfs:subClassOf :Person ;
    rdfs:label "Producer"@en ,
               "Productor"@es .

:Screenwriter rdf:type owl:Class ;
    rdfs:subClassOf :Person ;
    rdfs:label "Screenwriter"@en ,
               "Guionista"@es .

:Cinematographer rdf:type owl:Class ;
    rdfs:subClassOf :Person ;
    rdfs:label "Cinematographer"@en ,
               "Director de Fotografía"@es .

:Composer rdf:type owl:Class ;
    rdfs:subClassOf :Person ;
    rdfs:label "Composer"@en ,
               "Compositor"@es .

:Editor rdf:type owl:Class ;
    rdfs:subClassOf :Person ;
    rdfs:label "Editor"@en ,
               "Editor"@es .

###  Attribute
:Attribute rdf:type owl:Class ;
    rdfs:subClassOf :Entity ;
    rdfs:label "Attribute"@en ,
               "Atributo"@es ;
    rdfs:comment "Descriptive characteristics of movies"@en .

###  Genre
:Genre rdf:type owl:Class ;
    rdfs:subClassOf :Attribute ;
    owl:equivalentClass schema:Genre ,
                       movie:Genre ;
    rdfs:label "Genre"@en ,
               "Género"@es .

:MainGenre rdf:type owl:Class ;
    rdfs:subClassOf :Genre ;
    rdfs:label "Main Genre"@en ,
               "Género Principal"@es .

:Subgenre rdf:type owl:Class ;
    rdfs:subClassOf :Genre ;
    rdfs:label "Subgenre"@en ,
               "Subgénero"@es .

###  Keyword
:Keyword rdf:type owl:Class ;
    rdfs:subClassOf :Attribute ;
    rdfs:label "Keyword"@en ,
               "Palabra Clave"@es ;
    rdfs:comment "Descriptive keywords for the movie"@en .

###  NarrativeElement
:NarrativeElement rdf:type owl:Class ;
    rdfs:subClassOf :Attribute ;
    rdfs:label "Narrative Element"@en ,
               "Elemento Narrativo"@es ;
    rdfs:comment "Aspects of narrative structure and content"@en .

:Theme rdf:type owl:Class ;
    rdfs:subClassOf :NarrativeElement ;
    rdfs:label "Theme"@en ,
               "Tema"@es .

:Tone rdf:type owl:Class ;
    rdfs:subClassOf :NarrativeElement ;
    rdfs:label "Tone"@en ,
               "Tono"@es .

:DramaticTone rdf:type owl:Class ;
    rdfs:subClassOf :Tone ;
    rdfs:label "Dramatic Tone"@en ,
               "Tono Dramático"@es .

:ComedyTone rdf:type owl:Class ;
    rdfs:subClassOf :Tone ;
    rdfs:label "Comedy Tone"@en ,
               "Tono Cómico"@es .

:SuspensefulTone rdf:type owl:Class ;
    rdfs:subClassOf :Tone ;
    rdfs:label "Suspenseful Tone"@en ,
               "Tono Suspense"@es .

:RomanticTone rdf:type owl:Class ;
    rdfs:subClassOf :Tone ;
    rdfs:label "Romantic Tone"@en ,
               "Tono Romántico"@es .

:DarkTone rdf:type owl:Class ;
    rdfs:subClassOf :Tone ;
    rdfs:label "Dark Tone"@en ,
               "Tono Oscuro"@es .

:PlotStructure rdf:type owl:Class ;
    rdfs:subClassOf :NarrativeElement ;
    rdfs:label "Plot Structure"@en ,
               "Estructura de Trama"@es .

:LinearNarrative rdf:type owl:Class ;
    rdfs:subClassOf :PlotStructure ;
    rdfs:label "Linear Narrative"@en ,
               "Narrativa Lineal"@es .

:NonLinearNarrative rdf:type owl:Class ;
    rdfs:subClassOf :PlotStructure ;
    rdfs:label "Non-Linear Narrative"@en ,
               "Narrativa No Lineal"@es .

:EpisodicNarrative rdf:type owl:Class ;
    rdfs:subClassOf :PlotStructure ;
    rdfs:label "Episodic Narrative"@en ,
               "Narrativa Episódica"@es .

###  CulturalContext
:CulturalContext rdf:type owl:Class ;
    rdfs:subClassOf :Attribute ;
    rdfs:label "Cultural Context"@en ,
               "Contexto Cultural"@es .

:CountryOfOrigin rdf:type owl:Class ;
    rdfs:subClassOf :CulturalContext ;
    rdfs:label "Country of Origin"@en ,
               "País de Origen"@es .

:HistoricalPeriod rdf:type owl:Class ;
    rdfs:subClassOf :CulturalContext ;
    rdfs:label "Historical Period"@en ,
               "Período Histórico"@es .

:Contemporary rdf:type owl:Class ;
    rdfs:subClassOf :HistoricalPeriod ;
    rdfs:label "Contemporary"@en ,
               "Contemporáneo"@es .

:Historical rdf:type owl:Class ;
    rdfs:subClassOf :HistoricalPeriod ;
    rdfs:label "Historical"@en ,
               "Histórico"@es .

:Futuristic rdf:type owl:Class ;
    rdfs:subClassOf :HistoricalPeriod ;
    rdfs:label "Futuristic"@en ,
               "Futurista"@es .

:Language rdf:type owl:Class ;
    rdfs:subClassOf :CulturalContext ;
    rdfs:label "Language"@en ,
               "Idioma"@es .

###  AgeRatingCategory
:AgeRatingCategory rdf:type owl:Class ;
    rdfs:subClassOf :Attribute ;
    rdfs:label "Age Rating Category"@en ,
               "Categoría de Clasificación por Edad"@es .

:GeneralAudience rdf:type owl:Class ;
    rdfs:subClassOf :AgeRatingCategory ;
    rdfs:label "General Audience"@en ,
               "Audiencia General"@es .

:ParentalGuidance rdf:type owl:Class ;
    rdfs:subClassOf :AgeRatingCategory ;
    rdfs:label "Parental Guidance"@en ,
               "Orientación Parental"@es .

:Teen rdf:type owl:Class ;
    rdfs:subClassOf :AgeRatingCategory ;
    rdfs:label "Teen"@en ,
               "Adolescentes"@es .

:Mature rdf:type owl:Class ;
    rdfs:subClassOf :AgeRatingCategory ;
    rdfs:label "Mature"@en ,
               "Adultos"@es .

:AdultOnly rdf:type owl:Class ;
    rdfs:subClassOf :AgeRatingCategory ;
    rdfs:label "Adult Only"@en ,
               "Solo Adultos"@es .

###  Rating
:Rating rdf:type owl:Class ;
    rdfs:subClassOf :Attribute ;
    owl:equivalentClass schema:Rating ;
    rdfs:label "Rating"@en ,
               "Calificación"@es .

:CriticRating rdf:type owl:Class ;
    rdfs:subClassOf :Rating ;
    rdfs:label "Critic Rating"@en ,
               "Calificación de Críticos"@es .

:UserRating rdf:type owl:Class ;
    rdfs:subClassOf :Rating ;
    rdfs:label "User Rating"@en ,
               "Calificación de Usuarios"@es .

:AggregateRating rdf:type owl:Class ;
    rdfs:subClassOf :Rating ;
    rdfs:label "Aggregate Rating"@en ,
               "Calificación Agregada"@es .

###  Role
:Role rdf:type owl:Class ;
    rdfs:subClassOf :Entity ;
    rdfs:label "Role"@en ,
               "Rol"@es ;
    rdfs:comment "Intermediate relationship between Person and Movie"@en .

:ActingRole rdf:type owl:Class ;
    rdfs:subClassOf :Role ;
    rdfs:label "Acting Role"@en ,
               "Rol de Actuación"@es .

:LeadRole rdf:type owl:Class ;
    rdfs:subClassOf :ActingRole ;
    rdfs:label "Lead Role"@en ,
               "Rol Principal"@es .

:SupportingRole rdf:type owl:Class ;
    rdfs:subClassOf :ActingRole ;
    rdfs:label "Supporting Role"@en ,
               "Rol de Reparto"@es .

:CameoRole rdf:type owl:Class ;
    rdfs:subClassOf :ActingRole ;
    rdfs:label "Cameo Role"@en ,
               "Cameo"@es .

:CreativeRole rdf:type owl:Class ;
    rdfs:subClassOf :Role ;
    rdfs:label "Creative Role"@en ,
               "Rol Creativo"@es .

:PrimaryRole rdf:type owl:Class ;
    rdfs:subClassOf :CreativeRole ;
    rdfs:label "Primary Role"@en ,
               "Rol Primario"@es .

:CollaborativeRole rdf:type owl:Class ;
    rdfs:subClassOf :CreativeRole ;
    rdfs:label "Collaborative Role"@en ,
               "Rol Colaborativo"@es .

###  ProductionCompany
:ProductionCompany rdf:type owl:Class ;
    rdfs:subClassOf :Entity ;
    rdfs:label "Production Company"@en ,
               "Compañía de Producción"@es ;
    rdfs:comment "Studio or company that produces movies"@en .

###  Certification
:Certification rdf:type owl:Class ;
    rdfs:subClassOf :Entity ;
    rdfs:label "Certification"@en ,
               "Certificación"@es ;
    rdfs:comment "Age certification by country"@en .

###  Award
:Award rdf:type owl:Class ;
    rdfs:subClassOf :Entity ;
    owl:equivalentClass dbo:Award ;
    rdfs:label "Award"@en ,
               "Premio"@es .

:FilmAward rdf:type owl:Class ;
    rdfs:subClassOf :Award ;
    rdfs:label "Film Award"@en ,
               "Premio de Película"@es .

:BestPicture rdf:type owl:Class ;
    rdfs:subClassOf :FilmAward ;
    rdfs:label "Best Picture"@en ,
               "Mejor Película"@es .

:BestForeignFilm rdf:type owl:Class ;
    rdfs:subClassOf :FilmAward ;
    rdfs:label "Best Foreign Film"@en ,
               "Mejor Película Extranjera"@es .

:BestDocumentary rdf:type owl:Class ;
    rdfs:subClassOf :FilmAward ;
    rdfs:label "Best Documentary"@en ,
               "Mejor Documental"@es .

:PersonAward rdf:type owl:Class ;
    rdfs:subClassOf :Award ;
    rdfs:label "Person Award"@en ,
               "Premio Personal"@es .

:BestDirector rdf:type owl:Class ;
    rdfs:subClassOf :PersonAward ;
    rdfs:label "Best Director"@en ,
               "Mejor Director"@es .

:BestActor rdf:type owl:Class ;
    rdfs:subClassOf :PersonAward ;
    rdfs:label "Best Actor"@en ,
               "Mejor Actor"@es .

:BestActress rdf:type owl:Class ;
    rdfs:subClassOf :PersonAward ;
    rdfs:label "Best Actress"@en ,
               "Mejor Actriz"@es .

:BestSupportingActor rdf:type owl:Class ;
    rdfs:subClassOf :PersonAward ;
    rdfs:label "Best Supporting Actor"@en ,
               "Mejor Actor de Reparto"@es .

:BestSupportingActress rdf:type owl:Class ;
    rdfs:subClassOf :PersonAward ;
    rdfs:label "Best Supporting Actress"@en ,
               "Mejor Actriz de Reparto"@es .

:BestScreenplay rdf:type owl:Class ;
    rdfs:subClassOf :PersonAward ;
    rdfs:label "Best Screenplay"@en ,
               "Mejor Guion"@es .

###  AwardParticipation (Clase auxiliar)
:AwardParticipation rdf:type owl:Class ;
    rdfs:label "Award Participation"@en ,
               "Participación en Premio"@es ;
    rdfs:comment "N-ary relationship between entities and awards"@en .

###  MovieCluster (GraphRAG)
:MovieCluster rdf:type owl:Class ;
    rdfs:subClassOf :Entity ;
    rdfs:label "Movie Cluster"@en ,
               "Cluster de Películas"@es ;
    rdfs:comment "Grouping of similar movies detected by clustering algorithms (Louvain, Leiden) for GraphRAG. Enables hierarchical navigation and search space reduction for LLM."@en .

#################################################################
#    Object Properties - Movie ↔ Person Relations
#################################################################

:hasDirector rdf:type owl:ObjectProperty ;
    rdfs:domain :Movie ;
    rdfs:range :Director ;
    owl:inverseOf :isDirectorOf ;
    rdfs:label "has director"@en ,
               "tiene director"@es .

:isDirectorOf rdf:type owl:ObjectProperty ;
    rdfs:domain :Director ;
    rdfs:range :Movie ;
    rdfs:label "is director of"@en ,
               "es director de"@es .

:hasActor rdf:type owl:ObjectProperty ;
    rdfs:domain :Movie ;
    rdfs:range :Actor ;
    owl:inverseOf :isActorIn ;
    rdfs:label "has actor"@en ,
               "tiene actor"@es .

:isActorIn rdf:type owl:ObjectProperty ;
    rdfs:domain :Actor ;
    rdfs:range :Movie ;
    rdfs:label "is actor in"@en ,
               "es actor en"@es .

:hasProducer rdf:type owl:ObjectProperty ;
    rdfs:domain :Movie ;
    rdfs:range :Producer ;
    rdfs:label "has producer"@en ,
               "tiene productor"@es .

:hasScreenwriter rdf:type owl:ObjectProperty ;
    rdfs:domain :Movie ;
    rdfs:range :Screenwriter ;
    rdfs:label "has screenwriter"@en ,
               "tiene guionista"@es .

:hasCinematographer rdf:type owl:ObjectProperty ;
    rdfs:domain :Movie ;
    rdfs:range :Cinematographer ;
    rdfs:label "has cinematographer"@en ,
               "tiene director de fotografía"@es .

:hasComposer rdf:type owl:ObjectProperty ;
    rdfs:domain :Movie ;
    rdfs:range :Composer ;
    rdfs:label "has composer"@en ,
               "tiene compositor"@es .

:hasEditor rdf:type owl:ObjectProperty ;
    rdfs:domain :Movie ;
    rdfs:range :Editor ;
    rdfs:label "has editor"@en ,
               "tiene editor"@es .

#################################################################
#    Object Properties - Movie ↔ Attribute Relations
#################################################################

:hasGenre rdf:type owl:ObjectProperty ;
    rdfs:domain :Movie ;
    rdfs:range :Genre ;
    owl:inverseOf :isGenreOf ;
    rdfs:label "has genre"@en ,
               "tiene género"@es .

:isGenreOf rdf:type owl:ObjectProperty ;
    rdfs:domain :Genre ;
    rdfs:range :Movie ;
    rdfs:label "is genre of"@en ,
               "es género de"@es .

:hasMainGenre rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasGenre ;
    rdfs:domain :Movie ;
    rdfs:range :MainGenre ;
    rdfs:label "has main genre"@en ,
               "tiene género principal"@es .

:hasSubgenre rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasGenre ;
    rdfs:domain :Movie ;
    rdfs:range :Subgenre ;
    rdfs:label "has subgenre"@en ,
               "tiene subgénero"@es .

:hasKeyword rdf:type owl:ObjectProperty ;
    rdfs:domain :Movie ;
    rdfs:range :Keyword ;
    owl:inverseOf :isKeywordOf ;
    rdfs:label "has keyword"@en ,
               "tiene palabra clave"@es .

:isKeywordOf rdf:type owl:ObjectProperty ;
    rdfs:domain :Keyword ;
    rdfs:range :Movie ;
    rdfs:label "is keyword of"@en ,
               "es palabra clave de"@es .

:hasProductionCompany rdf:type owl:ObjectProperty ;
    rdfs:domain :Movie ;
    rdfs:range :ProductionCompany ;
    owl:inverseOf :producedMovie ;
    rdfs:label "has production company"@en ,
               "tiene compañía de producción"@es .

:producedMovie rdf:type owl:ObjectProperty ;
    rdfs:domain :ProductionCompany ;
    rdfs:range :Movie ;
    rdfs:label "produced movie"@en ,
               "produjo película"@es .

:hasCertification rdf:type owl:ObjectProperty ;
    rdfs:domain :Movie ;
    rdfs:range :Certification ;
    rdfs:label "has certification"@en ,
               "tiene certificación"@es .

:hasNarrativeElement rdf:type owl:ObjectProperty ;
    rdfs:domain :Movie ;
    rdfs:range :NarrativeElement ;
    rdfs:label "has narrative element"@en ,
               "tiene elemento narrativo"@es .

:hasTone rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasNarrativeElement ;
    rdfs:domain :Movie ;
    rdfs:range :Tone ;
    rdfs:label "has tone"@en ,
               "tiene tono"@es .

:hasTheme rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasNarrativeElement ;
    rdfs:domain :Movie ;
    rdfs:range :Theme ;
    rdfs:label "has theme"@en ,
               "tiene tema"@es .

:hasPlotStructure rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasNarrativeElement ;
    rdfs:domain :Movie ;
    rdfs:range :PlotStructure ;
    rdfs:label "has plot structure"@en ,
               "tiene estructura de trama"@es .

:hasCulturalContext rdf:type owl:ObjectProperty ;
    rdfs:domain :Movie ;
    rdfs:range :CulturalContext ;
    rdfs:label "has cultural context"@en ,
               "tiene contexto cultural"@es .

:hasCountryOfOrigin rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasCulturalContext ;
    rdfs:domain :Movie ;
    rdfs:range :CountryOfOrigin ;
    owl:inverseOf :isCountryOfOriginOf ;
    rdfs:label "has country of origin"@en ,
               "tiene país de origen"@es .

:isCountryOfOriginOf rdf:type owl:ObjectProperty ;
    rdfs:domain :CountryOfOrigin ;
    rdfs:range :Movie ;
    rdfs:label "is country of origin of"@en ,
               "es país de origen de"@es .

:hasHistoricalPeriod rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasCulturalContext ;
    rdfs:domain :Movie ;
    rdfs:range :HistoricalPeriod ;
    rdfs:label "has historical period"@en ,
               "tiene período histórico"@es .

:hasLanguage rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasCulturalContext ;
    rdfs:domain :Movie ;
    rdfs:range :Language ;
    owl:inverseOf :isLanguageOf ;
    rdfs:label "has language"@en ,
               "tiene idioma"@es .

:isLanguageOf rdf:type owl:ObjectProperty ;
    rdfs:domain :Language ;
    rdfs:range :Movie ;
    rdfs:label "is language of"@en ,
               "es idioma de"@es .

:hasAgeRating rdf:type owl:ObjectProperty ;
    rdfs:domain :Movie ;
    rdfs:range :AgeRatingCategory ;
    rdfs:label "has age rating"@en ,
               "tiene clasificación por edad"@es .

:hasRating rdf:type owl:ObjectProperty ;
    rdfs:domain :Movie ;
    rdfs:range :Rating ;
    rdfs:label "has rating"@en ,
               "tiene calificación"@es .

#################################################################
#    Object Properties - Person ↔ Role Relations
#################################################################

:hasRole rdf:type owl:ObjectProperty ;
    rdfs:domain :Person ;
    rdfs:range :Role ;
    rdfs:label "has role"@en ,
               "tiene rol"@es .

:playsRole rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasRole ;
    rdfs:domain :Actor ;
    rdfs:range :ActingRole ;
    rdfs:label "plays role"@en ,
               "interpreta rol"@es .

:performsCreativeRole rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasRole ;
    rdfs:domain :Person ;
    rdfs:range :CreativeRole ;
    rdfs:label "performs creative role"@en ,
               "realiza rol creativo"@es .

#################################################################
#    Object Properties - Role ↔ Movie Relations
#################################################################

:inMovie rdf:type owl:ObjectProperty ;
    rdfs:domain :Role ;
    rdfs:range :Movie ;
    rdfs:label "in movie"@en ,
               "en película"@es .

#################################################################
#    Object Properties - Award Relations
#################################################################

:hasAwardParticipation rdf:type owl:ObjectProperty ;
    rdfs:domain [ rdf:type owl:Class ;
                  owl:unionOf ( :Movie :Person )
                ] ;
    rdfs:range :AwardParticipation ;
    rdfs:label "has award participation"@en ,
               "tiene participación en premio"@es .

:hasAward rdf:type owl:ObjectProperty ;
    rdfs:domain :AwardParticipation ;
    rdfs:range :Award ;
    rdfs:label "has award"@en ,
               "tiene premio"@es .

:forEntity rdf:type owl:ObjectProperty ;
    rdfs:domain :AwardParticipation ;
    rdfs:range [ rdf:type owl:Class ;
                 owl:unionOf ( :Movie :Person )
               ] ;
    rdfs:label "for entity"@en ,
               "para entidad"@es .

:receivedAward rdf:type owl:ObjectProperty ;
    rdfs:domain [ rdf:type owl:Class ;
                  owl:unionOf ( :Movie :Person )
                ] ;
    rdfs:range :Award ;
    rdfs:label "received award"@en ,
               "recibió premio"@es .

:nominatedFor rdf:type owl:ObjectProperty ;
    rdfs:domain [ rdf:type owl:Class ;
                  owl:unionOf ( :Movie :Person )
                ] ;
    rdfs:range :Award ;
    rdfs:label "nominated for"@en ,
               "nominado para"@es .

#################################################################
#    Object Properties - Movie ↔ Movie Relations
#################################################################

:isSimilarTo rdf:type owl:ObjectProperty ,
                      owl:SymmetricProperty ;
    rdfs:domain :Movie ;
    rdfs:range :Movie ;
    rdfs:label "is similar to"@en ,
               "es similar a"@es ;
    rdfs:comment "Symmetric property indicating movie similarity. If A is similar to B, then B is similar to A"@en ,
                 "Propiedad simétrica que indica similitud entre películas. Si A es similar a B, entonces B es similar a A"@es .

