#################################################################

:belongsToCluster rdf:type owl:ObjectProperty ;
    rdfs:domain :Movie ;
    rdfs:range :MovieCluster ;
    owl:inverseOf :containsMovie ;
    rdfs:label "belongs to cluster"@en ,
               "pertenece a cluster"@es ;
    rdfs:comment "Indica que una película pertenece a un cluster detectado por algoritmos de comunidad (Louvain/Leiden)"@es .

:containsMovie rdf:type owl:ObjectProperty ;
    rdfs:domain :MovieCluster ;
    rdfs:range :Movie ;
    rdfs:label "contains movie"@en ,
               "contiene película"@es ;
    rdfs:comment "Inversa de belongsToCluster. Permite consultar todas las películas de un cluster"@es .

