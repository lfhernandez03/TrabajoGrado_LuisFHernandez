#################################################################
#    Axioms and Constraints
#################################################################

#================================================================
# CARDINALITY CONSTRAINTS
#================================================================

# A movie MUST have at least one director
:Movie rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :hasDirector ;
                         owl:minCardinality "1"^^xsd:nonNegativeInteger
                       ] .

# A movie MUST have at least one main genre
:Movie rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :hasMainGenre ;
                         owl:minCardinality "1"^^xsd:nonNegativeInteger
                       ] .

# A movie MUST have exactly one title
:Movie rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :hasTitle ;
                         owl:cardinality "1"^^xsd:nonNegativeInteger
                       ] .

# A movie MUST have exactly one release date
:Movie rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :releaseDate ;
                         owl:cardinality "1"^^xsd:nonNegativeInteger
                       ] .

# A MovieCluster MUST have at least one movie
:MovieCluster rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty :containsMovie ;
                                owl:minCardinality "1"^^xsd:nonNegativeInteger
                              ] .

# A MovieCluster MUST have exactly one ID
:MovieCluster rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty :clusterID ;
                                owl:cardinality "1"^^xsd:nonNegativeInteger
                              ] .

# ---- IMPORTANT: N-ARY PATTERN FOR AWARDS ----
# A Movie or Person MAY have MULTIPLE awards via multiple AwardParticipation instances.
# Each AwardParticipation represents ONE participation in ONE specific award.
# Example: If "Oppenheimer" won 3 Oscars, it will have 3 AwardParticipation instances.

# AwardParticipation must have exactly one award (but a movie can have many AwardParticipation instances)
:AwardParticipation rdfs:subClassOf [ rdf:type owl:Restriction ;
                                      owl:onProperty :hasAward ;
                                      owl:cardinality "1"^^xsd:nonNegativeInteger
                                    ] .

# AwardParticipation must have exactly one entity
:AwardParticipation rdfs:subClassOf [ rdf:type owl:Restriction ;
                                      owl:onProperty :forEntity ;
                                      owl:cardinality "1"^^xsd:nonNegativeInteger
                                    ] .

# AwardParticipation must have exactly one year
:AwardParticipation rdfs:subClassOf [ rdf:type owl:Restriction ;
                                      owl:onProperty :awardYear ;
                                      owl:cardinality "1"^^xsd:nonNegativeInteger
                                    ] .

# AwardParticipation must have exactly one result (Winner, Nominee, Shortlisted)
:AwardParticipation rdfs:subClassOf [ rdf:type owl:Restriction ;
                                      owl:onProperty :awardResult ;
                                      owl:cardinality "1"^^xsd:nonNegativeInteger
                                    ] .

#================================================================
# VALUE RANGE CONSTRAINTS
#================================================================

# Runtime must be positive (greater than 0 minutes)
:Movie rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :runtime ;
                         owl:allValuesFrom [ rdf:type rdfs:Datatype ;
                                           owl:onDatatype xsd:integer ;
                                           owl:withRestrictions ( [ xsd:minInclusive "1"^^xsd:integer ]
                                                                 [ xsd:maxInclusive "1000"^^xsd:integer ]
                                                               )
                                         ]
                       ] .

# Rating value must be between 0 and 10
:Rating rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :ratingValue ;
                          owl:allValuesFrom [ rdf:type rdfs:Datatype ;
                                             owl:onDatatype xsd:decimal ;
                                             owl:withRestrictions ( [ xsd:minInclusive "0.0"^^xsd:decimal ]
                                                                   [ xsd:maxInclusive "10.0"^^xsd:decimal ]
                                                                 )
                                           ]
                        ] .

# Popularity must be non-negative
:Movie rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :hasPopularity ;
                         owl:allValuesFrom [ rdf:type rdfs:Datatype ;
                                           owl:onDatatype xsd:decimal ;
                                           owl:withRestrictions ( [ xsd:minInclusive "0.0"^^xsd:decimal ] )
                                         ]
                       ] .

# Similarity score must be between 0 and 1
:Movie rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :hasSimilarityScore ;
                         owl:allValuesFrom [ rdf:type rdfs:Datatype ;
                                           owl:onDatatype xsd:decimal ;
                                           owl:withRestrictions ( [ xsd:minInclusive "0.0"^^xsd:decimal ]
                                                                 [ xsd:maxInclusive "1.0"^^xsd:decimal ]
                                                               )
                                         ]
                       ] .

# Cluster cohesion must be between 0 and 1
:MovieCluster rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty :clusterCohesion ;
                                owl:allValuesFrom [ rdf:type rdfs:Datatype ;
                                                  owl:onDatatype xsd:decimal ;
                                                  owl:withRestrictions ( [ xsd:minInclusive "0.0"^^xsd:decimal ]
                                                                        [ xsd:maxInclusive "1.0"^^xsd:decimal ]
                                                                      )
                                                ]
                              ] .

# Cluster centrality must be between 0 and 1
:MovieCluster rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty :clusterCentrality ;
                                owl:allValuesFrom [ rdf:type rdfs:Datatype ;
                                                  owl:onDatatype xsd:decimal ;
                                                  owl:withRestrictions ( [ xsd:minInclusive "0.0"^^xsd:decimal ]
                                                                        [ xsd:maxInclusive "1.0"^^xsd:decimal ]
                                                                      )
                                                ]
                              ] .

# Cluster size must be positive
:MovieCluster rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty :clusterSize ;
                                owl:allValuesFrom [ rdf:type rdfs:Datatype ;
                                                  owl:onDatatype xsd:integer ;
                                                  owl:withRestrictions ( [ xsd:minInclusive "1"^^xsd:integer ] )
                                                ]
                              ] .

# Minimum age must be non-negative
:AgeRatingCategory rdfs:subClassOf [ rdf:type owl:Restriction ;
                                     owl:onProperty :minimumAge ;
                                     owl:allValuesFrom [ rdf:type rdfs:Datatype ;
                                                       owl:onDatatype xsd:integer ;
                                                       owl:withRestrictions ( [ xsd:minInclusive "0"^^xsd:integer ]
                                                                             [ xsd:maxInclusive "21"^^xsd:integer ]
                                                                           )
                                                     ]
                                   ] .

# Award prestige must be between 0 and 1
:Award rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :awardPrestige ;
                         owl:allValuesFrom [ rdf:type rdfs:Datatype ;
                                           owl:onDatatype xsd:float ;
                                           owl:withRestrictions ( [ xsd:minInclusive "0.0"^^xsd:float ]
                                                                 [ xsd:maxInclusive "1.0"^^xsd:float ]
                                                               )
                                         ]
                       ] .

# Tone intensity must be between 0 and 1
:Tone rdfs:subClassOf [ rdf:type owl:Restriction ;
                        owl:onProperty :toneIntensity ;
                        owl:allValuesFrom [ rdf:type rdfs:Datatype ;
                                          owl:onDatatype xsd:float ;
                                          owl:withRestrictions ( [ xsd:minInclusive "0.0"^^xsd:float ]
                                                                [ xsd:maxInclusive "1.0"^^xsd:float ]
                                                              )
                                        ]
                      ] .

# TMDb rating must be between 0 and 10
:Movie rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :hasTMDbRating ;
                         owl:allValuesFrom [ rdf:type rdfs:Datatype ;
                                           owl:onDatatype xsd:decimal ;
                                           owl:withRestrictions ( [ xsd:minInclusive "0.0"^^xsd:decimal ]
                                                                 [ xsd:maxInclusive "10.0"^^xsd:decimal ]
                                                               )
                                         ]
                       ] .

# IMDb rating must be between 0 and 10
:Movie rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :hasIMDbRating ;
                         owl:allValuesFrom [ rdf:type rdfs:Datatype ;
                                           owl:onDatatype xsd:decimal ;
                                           owl:withRestrictions ( [ xsd:minInclusive "0.0"^^xsd:decimal ]
                                                                 [ xsd:maxInclusive "10.0"^^xsd:decimal ]
                                                               )
                                         ]
                       ] .

# MovieLens average rating must be between 0 and 5
:Movie rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :hasAverageRating ;
                         owl:allValuesFrom [ rdf:type rdfs:Datatype ;
                                           owl:onDatatype xsd:decimal ;
                                           owl:withRestrictions ( [ xsd:minInclusive "0.0"^^xsd:decimal ]
                                                                 [ xsd:maxInclusive "5.0"^^xsd:decimal ]
                                                               )
                                         ]
                       ] .

# Metascore must be between 0 and 100
:Movie rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :hasMetascore ;
                         owl:allValuesFrom [ rdf:type rdfs:Datatype ;
                                           owl:onDatatype xsd:integer ;
                                           owl:withRestrictions ( [ xsd:minInclusive "0"^^xsd:integer ]
                                                                 [ xsd:maxInclusive "100"^^xsd:integer ]
                                                               )
                                         ]
                       ] .

# Vote counts must be non-negative
:Movie rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :hasVoteCount ;
                         owl:allValuesFrom [ rdf:type rdfs:Datatype ;
                                           owl:onDatatype xsd:integer ;
                                           owl:withRestrictions ( [ xsd:minInclusive "0"^^xsd:integer ] )
                                         ]
                       ] .

:Movie rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :hasTMDbVoteCount ;
                         owl:allValuesFrom [ rdf:type rdfs:Datatype ;
                                           owl:onDatatype xsd:integer ;
                                           owl:withRestrictions ( [ xsd:minInclusive "0"^^xsd:integer ] )
                                         ]
                       ] .

:Movie rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :hasIMDbVoteCount ;
                         owl:allValuesFrom [ rdf:type rdfs:Datatype ;
                                           owl:onDatatype xsd:integer ;
                                           owl:withRestrictions ( [ xsd:minInclusive "0"^^xsd:integer ] )
                                         ]
                       ] .

:Movie rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :hasRatingCount ;
                         owl:allValuesFrom [ rdf:type rdfs:Datatype ;
                                           owl:onDatatype xsd:integer ;
                                           owl:withRestrictions ( [ xsd:minInclusive "0"^^xsd:integer ] )
                                         ]
                       ] .

# Budget and BoxOffice must be non-negative
:Movie rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :hasBudget ;
                         owl:allValuesFrom [ rdf:type rdfs:Datatype ;
                                           owl:onDatatype xsd:decimal ;
                                           owl:withRestrictions ( [ xsd:minInclusive "0.0"^^xsd:decimal ] )
                                         ]
                       ] .

:Movie rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :hasBoxOffice ;
                         owl:allValuesFrom [ rdf:type rdfs:Datatype ;
                                           owl:onDatatype xsd:decimal ;
                                           owl:withRestrictions ( [ xsd:minInclusive "0.0"^^xsd:decimal ] )
                                         ]
                       ] .

#================================================================
# FUNCTIONAL PROPERTIES (UNIQUE VALUES)
#================================================================

# A movie has exactly one title
:hasTitle rdf:type owl:FunctionalProperty .

# A movie has exactly one original title
:hasOriginalTitle rdf:type owl:FunctionalProperty .

# A movie has exactly one release date
:releaseDate rdf:type owl:FunctionalProperty .

# A movie has exactly one runtime
:runtime rdf:type owl:FunctionalProperty .

# A person has exactly one name
:hasName rdf:type owl:FunctionalProperty .

# A cluster has exactly one ID
:clusterID rdf:type owl:FunctionalProperty .

# A cluster has exactly one label
:clusterLabel rdf:type owl:FunctionalProperty .

# A cluster has exactly one size
:clusterSize rdf:type owl:FunctionalProperty .

# External IDs are functional (a movie has at most one ID per source)
:hasIMDbID rdf:type owl:FunctionalProperty .
:hasTMDbID rdf:type owl:FunctionalProperty .
:hasPosterUrl rdf:type owl:FunctionalProperty .
:hasBackdropUrl rdf:type owl:FunctionalProperty .

# Financial values are functional
:hasBudget rdf:type owl:FunctionalProperty .
:hasBoxOffice rdf:type owl:FunctionalProperty .

# Aggregate metrics are functional (single value per movie)
:hasPopularity rdf:type owl:FunctionalProperty .
:hasVoteCount rdf:type owl:FunctionalProperty .
:hasAverageRating rdf:type owl:FunctionalProperty .
:hasRatingCount rdf:type owl:FunctionalProperty .
:hasTMDbRating rdf:type owl:FunctionalProperty .
:hasTMDbVoteCount rdf:type owl:FunctionalProperty .
:hasIMDbRating rdf:type owl:FunctionalProperty .
:hasIMDbVoteCount rdf:type owl:FunctionalProperty .
:hasMetascore rdf:type owl:FunctionalProperty .
:hasOriginalLanguage rdf:type owl:FunctionalProperty .

# Entity identifier attributes are functional
:genreName rdf:type owl:FunctionalProperty .
:companyName rdf:type owl:FunctionalProperty .

#================================================================
# DISJOINT CLASSES (MUTUALLY EXCLUSIVE)
#================================================================

# Movie types are disjoint
:FeatureFilm owl:disjointWith :Documentary ,
                               :ShortFilm ,
                               :AnimatedFilm .

:Documentary owl:disjointWith :ShortFilm ,
                               :AnimatedFilm .

:ShortFilm owl:disjointWith :AnimatedFilm .

# Award types are disjoint
:FilmAward owl:disjointWith :PersonAward .

# Tones are mutually disjoint
:DramaticTone owl:disjointWith :ComedyTone ,
                                :SuspensefulTone ,
                                :RomanticTone ,
                                :DarkTone .

:ComedyTone owl:disjointWith :SuspensefulTone ,
                              :RomanticTone ,
                              :DarkTone .

:SuspensefulTone owl:disjointWith :RomanticTone ,
                                   :DarkTone .

:RomanticTone owl:disjointWith :DarkTone .

# Creative and acting roles are different types
:ActingRole owl:disjointWith :CreativeRole .

# MainGenre and Subgenre are disjoint
:MainGenre owl:disjointWith :Subgenre .

# Historical periods are disjoint
:Contemporary owl:disjointWith :Historical ,
                                :Futuristic .

:Historical owl:disjointWith :Futuristic .

# Age categories are disjoint
:GeneralAudience owl:disjointWith :ParentalGuidance ,
                                   :Teen ,
                                   :Mature ,
                                   :AdultOnly .

:ParentalGuidance owl:disjointWith :Teen ,
                                    :Mature ,
                                    :AdultOnly .

:Teen owl:disjointWith :Mature ,
                        :AdultOnly .

:Mature owl:disjointWith :AdultOnly .

# Main ontology classes are mutually disjoint (AllDisjointClasses)
[] rdf:type owl:AllDisjointClasses ;
   owl:members ( :Movie :Person :Attribute :Role
                 :ProductionCompany :Certification :Award
                 :AwardParticipation :MovieCluster ) .

# Person subclasses are mutually disjoint
[] rdf:type owl:AllDisjointClasses ;
   owl:members ( :Director :Actor :Producer :Screenwriter
                 :Cinematographer :Composer :Editor ) .

# Rating subclasses are mutually disjoint
[] rdf:type owl:AllDisjointClasses ;
   owl:members ( :CriticRating :UserRating :AggregateRating ) .

# NarrativeElement subclasses are mutually disjoint
[] rdf:type owl:AllDisjointClasses ;
   owl:members ( :Theme :Tone :PlotStructure ) .

#================================================================
# TRANSITIVE PROPERTIES (For inference)
#================================================================

# If A is similar to B, and B is similar to C, then A is similar to C
# (Commented out because it may generate too many inferences in GraphRAG)
# :isSimilarTo rdf:type owl:TransitiveProperty .

#================================================================
# COMPLEX SEMANTIC CONSTRAINTS
#================================================================

# A Director must have directed at least one movie
:Director rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty :isDirectorOf ;
                            owl:minCardinality "1"^^xsd:nonNegativeInteger
                          ] .

# An Actor must have acted in at least one movie
:Actor rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :isActorIn ;
                         owl:minCardinality "1"^^xsd:nonNegativeInteger
                       ] .

# A ProductionCompany must have produced at least one movie
:ProductionCompany rdfs:subClassOf [ rdf:type owl:Restriction ;
                                     owl:onProperty :producedMovie ;
                                     owl:minCardinality "1"^^xsd:nonNegativeInteger
                                   ] .

# A Genre must be associated with at least one movie
:Genre rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :isGenreOf ;
                         owl:minCardinality "1"^^xsd:nonNegativeInteger
                       ] .

# A person MUST have exactly one name
:Person rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :hasName ;
                          owl:cardinality "1"^^xsd:nonNegativeInteger
                        ] .

# A genre MUST have exactly one name
:Genre rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :genreName ;
                         owl:cardinality "1"^^xsd:nonNegativeInteger
                       ] .

# A company MUST have exactly one name
:ProductionCompany rdfs:subClassOf [ rdf:type owl:Restriction ;
                                     owl:onProperty :companyName ;
                                     owl:cardinality "1"^^xsd:nonNegativeInteger
                                   ] .

# A movie can have at most one runtime
:Movie rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :runtime ;
                         owl:maxCardinality "1"^^xsd:nonNegativeInteger
                       ] .

#================================================================
# GRAPHRAG CONSTRAINTS
#================================================================

# A movie with plotSummary should have hasContextualDescription
# (To ensure RAG has enriched context)
:Movie rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :hasPlotSummary ;
                         owl:maxCardinality "1"^^xsd:nonNegativeInteger
                       ] .

:Movie rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :hasContextualDescription ;
                         owl:maxCardinality "1"^^xsd:nonNegativeInteger
                       ] .

# A movie can belong to multiple clusters (multi-level hierarchy)
# But should belong to at least one cluster for efficient GraphRAG
# (Commented out to allow movies without a cluster during initial construction)
# :Movie rdfs:subClassOf [ rdf:type owl:Restriction ;
#                          owl:onProperty :belongsToCluster ;
#                          owl:minCardinality "1"^^xsd:nonNegativeInteger
#                        ] .

#################################################################
#    Example Instances (Optional - for testing)
#################################################################

# Genre examples
:Action rdf:type :MainGenre ;
    :genreName "Action"@en ,
               "Acción"@es ;
    :genreDescription "High-energy films featuring physical stunts and chases"@en .

:Drama rdf:type :MainGenre ;
    :genreName "Drama"@en ;
    :genreDescription "Character-driven stories with emotional depth"@en .

:Comedy rdf:type :MainGenre ;
    :genreName "Comedy"@en ,
               "Comedia"@es ;
    :genreDescription "Films designed to provoke laughter"@en .

:SciFi rdf:type :MainGenre ;
    :genreName "Science Fiction"@en ,
               "Ciencia Ficción"@es ;
    :genreDescription "Speculative fiction based on scientific concepts"@en .

:Horror rdf:type :MainGenre ;
    :genreName "Horror"@en ,
               "Terror"@es ;
    :genreDescription "Films designed to frighten and invoke fear"@en .

# Tone examples
:DramaticToneInstance rdf:type :DramaticTone ;
    :toneName "Dramatic"@en ,
               "Dramático"@es ;
    :toneIntensity "0.8"^^xsd:float .

:ComedyToneInstance rdf:type :ComedyTone ;
    :toneName "Comedy"@en ,
               "Cómico"@es ;
    :toneIntensity "0.7"^^xsd:float .

# Age rating examples
:PG rdf:type :ParentalGuidance ;
    :ratingCode "PG" ;
    :ratingDescription "Parental Guidance Suggested"@en ;
    :minimumAge "0"^^xsd:integer .

:PG13 rdf:type :Teen ;
    :ratingCode "PG-13" ;
    :ratingDescription "Parents Strongly Cautioned"@en ;
    :minimumAge "13"^^xsd:integer .

:R rdf:type :Mature ;
    :ratingCode "R" ;
    :ratingDescription "Restricted"@en ;
    :minimumAge "17"^^xsd:integer .

# Award examples
:Oscar_BestPicture rdf:type :BestPicture ;
    :awardName "Academy Award for Best Picture"@en ;
    :awardingBody "Academy of Motion Picture Arts and Sciences" ;
    :awardPrestige "1.0"^^xsd:float .

:Oscar_BestDirector rdf:type :BestDirector ;
    :awardName "Academy Award for Best Director"@en ;
    :awardingBody "Academy of Motion Picture Arts and Sciences" ;
    :awardPrestige "0.95"^^xsd:float .

# Country examples
:USA rdf:type :CountryOfOrigin ;
    :countryName "United States"@en ,
                 "Estados Unidos"@es ;
    :countryCode "US" .

:UK rdf:type :CountryOfOrigin ;
    :countryName "United Kingdom"@en ,
                 "Reino Unido"@es ;
    :countryCode "GB" .

:France rdf:type :CountryOfOrigin ;
    :countryName "France"@en ,
                 "Francia"@es ;
    :countryCode "FR" .

# Language examples
:English rdf:type :Language ;
    :languageName "English"@en ,
                  "Inglés"@es ;
    :languageCode "en" .

:Spanish rdf:type :Language ;
    :languageName "Spanish"@en ,
                  "Español"@es ;
    :languageCode "es" .

:French rdf:type :Language ;
    :languageName "French"@en ,
                  "Francés"@es ;
    :languageCode "fr" .

# Historical period examples
:ModernEra rdf:type :Contemporary ;
    :periodName "Modern Era"@en ,
                "Era Moderna"@es ;
    :periodStartYear "2000"^^xsd:gYear .

:GoldenAgeOfHollywood rdf:type :Historical ;
    :periodName "Golden Age of Hollywood"@en ;
    :periodStartYear "1930"^^xsd:gYear ;
    :periodEndYear "1960"^^xsd:gYear .

#################################################################
#    Anotaciones Adicionales
#################################################################

<http://www.semanticweb.org/movierecommendation/ontologies/2025/movie-ontology>
    rdfs:comment """
    Cinematographic domain ontology designed for contextualized recommendation systems.

    Key features:
    - Multidimensional modeling of cinematographic content
    - Integration with Linked Open Data vocabularies (Schema.org, DBpedia, FOAF)
    - Support for narrative, cultural, and technical elements
    - Bridge properties for integration with context-ontology.ttl
    - Extensibility through ontological design patterns

    Author: Luis Fernando Hernández Solís
    Institution: Universidad del Valle - Escuela de Ingeniería de Sistemas y Computación
    Year: 2026

    """@en .


